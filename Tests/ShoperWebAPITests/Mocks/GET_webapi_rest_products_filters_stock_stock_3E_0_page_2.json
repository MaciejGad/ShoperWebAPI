 mody.\u00a0<\/p>","active":"1","lang_id":"1","isdefault":"0","seo_title":"","seo_description":"","seo_keywords":"","order":"1","main_page":"0","main_page_order":"0","booster":"","seo_url":"","permalink":"https:\/\/sklep173975.shoparena.pl\/pl\/p\/Okulary-sloneczne-True-Black\/37"}},"options":[],"options_non_stock":[],"attributes":{"5":[],"6":[],"7":[]},"related":[36],"main_image":{"gfx_id":"47","name":"07c.jpg","unic_name":"47","order":"1","hidden":"0","translations":{"pl_PL":{"translation_id":"47","gfx_id":"47","name":"07c.jpg","description":"","lang_id":"1"}},"extension":"jpg"},"feeds_excludes":[],"tags":[],"safety_information":{"gpsr_producer_id":null,"gpsr_importer_id":null,"gpsr_responsible_id":null,"gpsr_certificates":[]}},{"product_id":"38","producer_id":"18","group_id":"8","tax_id":"1","add_date":"2023-10-05 12:33:16","edit_date":"2023-12-12 09:04:58","other_price":"0.00","pkwiu":"","unit_id":"1","in_loyalty":"0","loyalty_score":null,"loyalty_price":null,"bestseller":"0","newproduct":"0","dimension_w":"0.0000","dimension_h":"0.0000","dimension_l":"0.0000","vol_weight":"0.0000","currency_id":null,"gauge_id":null,"unit_price_calculation":"0","type":"0","category_id":26,"categories":[26],"is_product_of_day":true,"is_digital":0,"collections":[],"promo_price":null,"code":"257D-79557","ean":"","stock":{"stock_id":"46","extended":"0","price":"336.00","price_type":"1","price_buying":"0.00","price_buying_net":"0.00","stock":"10","package":"0","warn_level":"1","sold":"0","weight":"1","weight_type":"1","active":"1","default":"0","product_id":"38","availability_id":null,"delivery_id":"5","gfx_id":null,"code":"257D-79557","ean":"","comp_weight":"1","comp_price":"336.00","comp_promo_price":"336.00","price_wholesale":"336.00","comp_price_wholesale":"336.00","comp_promo_price_wholesale":"336.00","price_special":"336.00","comp_price_special":"336.00","comp_promo_price_special":"336.00","price_type_wholesale":"1","price_type_special":"1","calculation_unit_id":null,"calculati